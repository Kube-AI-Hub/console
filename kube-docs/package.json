{
  "name": "kube-ai-hub-website",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "description": "Kube AI Hub documentation website",
  "scripts": {
    "build": "hugo build --baseURL ${HUGO_BASEURL:-/kube-docs/} && npx pagefind --site public",
    "dev": "rm -rf public/ resources/ && hugo --baseURL 'http://localhost:1313/kube-docs/' && npx pagefind --site public && cp -r public/pagefind static/ && hugo server -D",
    "preview": "hugo && npx pagefind --site public --serve"
  },
  "devDependencies": {
    "pagefind": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

