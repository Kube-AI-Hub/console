  "name": "kubesphere-console",
  "private": true,
  "resolutions": {
    "@types/react": "17.0.2",
    "@types/react-dom": "17.0.2"
  },
  "scripts": {
    "build": "yarn build:client && yarn build:server",
    "build:client": "webpack --mode production --config scripts/webpack.prod.js --stats errors-only",
    "build:e2e": "webpack --mode production --config scripts/webpack.e2e.js --stats errors-only",
    "build:server": "webpack --mode production --config scripts/webpack.server.js --stats errors-only",
    "dev:client": "cross-env NODE_ENV=development webpack serve --config scripts/webpack.dev.js",
    "dev:server": "cross-env NODE_ENV=development nodemon -w ./common -w ./server -e js,yaml server/server.js",
    "lint": "eslint src/**/*.jsx src/**/*.js",
    "postinstall": "rimraf node_modules/.cache",
    "prebuild": "rimraf dist",
    "release": "standard-version",
    "serve": "NODE_ENV=production node server/server.js",
    "start": "concurrently -k --raw \"yarn dev:client\" \"yarn dev:server\"",
    "test": "jest",
    "test:e2e": "cypress run",
    "storybook:build": "yarn workspace @kube-design/components build-storybook",
    "storybook:start": "yarn workspace @kube-design/components start"
  },
  "version": "3.4.2",
  "workspaces": [
    "packages/*"
  ]
}